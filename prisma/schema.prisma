generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id
  name  String @unique
  users User[]

  @@map("roles")
}

model Organization {
  id       Int          @id @default(autoincrement())
  name     String       @unique
  managers ManagerOrg[]
  clients  Client[]

  @@map("organizations")
}

model User {
  id              Int               @id @default(autoincrement())
  name            String
  role_id         Int
  email           String            @unique
  password        String
  phone           String?
  role            Role              @relation(fields: [role_id], references: [id])
  managerOrgs     ManagerOrg[]      @relation("ManagerOrganizations")
  managerSalesmen ManagerSalesman[] @relation("ManagerSalesmen")
  salesmanManager ManagerSalesman[] @relation("SalesmanManagers")
  assignedClients Client[]          @relation("AssignedClients")
  assignedTasks   Task[]            @relation("AssignedTasks")
  createdTasks    Task[]            @relation("CreatedTasks")
  clientLogs      ClientLog[]       @relation("LogAuthor")
  kpiLogs         SalesmanKpiLog[]  @relation("SalesmanKpi")
  assignedClientTasks ClientTask[]  @relation("AssignedClientTasks")
  createdClientTasks  ClientTask[]  @relation("CreatedClientTasks")

  @@map("users")
}

model ManagerOrg {
  manager_id Int
  org_id     Int
  manager    User         @relation("ManagerOrganizations", fields: [manager_id], references: [id], onDelete: Cascade)
  org        Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)

  @@id([manager_id, org_id])
  @@map("manager_org")
}

model ManagerSalesman {
  manager_id  Int
  salesman_id Int
  manager     User @relation("ManagerSalesmen", fields: [manager_id], references: [id], onDelete: Cascade)
  salesman    User @relation("SalesmanManagers", fields: [salesman_id], references: [id], onDelete: Cascade)

  @@id([manager_id, salesman_id])
  @@map("manager_salesman")
}

model Client {
  id                         Int          @id @default(autoincrement())
  name                       String
  contact_person_name        String
  contact_no                 String
  location_coordinates       String?
  mail_id                    String?
  contact_person_designation String?
  assigned_salesman_id       Int
  org_id                     Int
  notes                        String?
  status                       String
  checklist_kyc_verified       Boolean      @default(false)
  checklist_agreement_signed   Boolean      @default(false)
  checklist_rate_card_approved Boolean      @default(false)
  checklist_integration_setup  Boolean      @default(false)
  checklist_dispatch_confirmed Boolean      @default(false)
  checklist_billing_verified   Boolean      @default(false)
  checklist_portal_created     Boolean      @default(false)
  checklist_first_shipment     Boolean      @default(false)
  created_at                   DateTime     @default(now())
  assignedSalesman             User         @relation("AssignedClients", fields: [assigned_salesman_id], references: [id])
  organization                 Organization @relation(fields: [org_id], references: [id])
  logs                         ClientLog[]
  clientTasks                  ClientTask[]

  @@index([assigned_salesman_id])
  @@index([org_id])
  @@map("clients")
}

model ClientLog {
  id         Int      @id @default(autoincrement())
  client_id  Int
  action     String
  created_at DateTime @default(now())
  done_by    Int
  client     Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  author     User     @relation("LogAuthor", fields: [done_by], references: [id])

  @@index([done_by, created_at])
  @@index([client_id, created_at])
  @@map("client_logs")
}

model Task {
  id             Int      @id @default(autoincrement())
  assigned_to_id Int
  created_by_id  Int
  description    String
  due_date       DateTime
  notification   Boolean  @default(false)
  status         String
  assignedTo     User     @relation("AssignedTasks", fields: [assigned_to_id], references: [id])
  createdBy      User     @relation("CreatedTasks", fields: [created_by_id], references: [id])

  @@index([assigned_to_id, due_date])
  @@index([created_by_id])
  @@map("tasks")
}

model SalesmanKpiLog {
  id          Int    @id @default(autoincrement())
  salesman_id Int
  action      String
  salesman    User   @relation("SalesmanKpi", fields: [salesman_id], references: [id], onDelete: Cascade)

  @@map("salesman_kpi_logs")
}

model ClientTask {
  id             Int      @id @default(autoincrement())
  client_id      Int
  assigned_to_id Int
  created_by_id  Int
  description    String
  due_date       DateTime
  status         String
  client         Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  assignedTo     User     @relation("AssignedClientTasks", fields: [assigned_to_id], references: [id], onDelete: Cascade)
  createdBy      User     @relation("CreatedClientTasks", fields: [created_by_id], references: [id], onDelete: Cascade)

  @@index([client_id, due_date])
  @@index([assigned_to_id])
  @@map("client_tasks")
}
